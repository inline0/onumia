{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "tabs",
        "props": {
          "name": "loginActivityTab",
          "defaultValue": "logins"
        },
        "children": [
          {
            "type": "tab",
            "props": {
              "value": "logins",
              "label": "{{messages.tabs.logins}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "loginActivityLogins",
                  "entry": "loginActivityLogins",
                  "label": "{{messages.logins.label}}",
                  "description": "{{messages.logins.description}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "occurredAt",
                      "direction": "desc"
                    }
                  },
                  "columns": [
                    {
                      "key": "occurredAtLabel",
                      "label": "{{messages.columns.time}}"
                    },
                    {
                      "key": "userLogin",
                      "label": "{{messages.columns.user}}"
                    },
                    {
                      "key": "resultLabel",
                      "label": "{{messages.columns.result}}"
                    },
                    {
                      "key": "ipDisplay",
                      "label": "{{messages.columns.ipHash}}"
                    },
                    {
                      "key": "userAgentPreview",
                      "label": "{{messages.columns.userAgent}}"
                    }
                  ],
                  "editDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.logins.drawerDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "settings",
              "label": "{{messages.tabs.settings}}"
            },
            "children": [
              {
                "type": "field",
                "props": {
                  "label": "{{messages.logging.label}}",
                  "description": "{{messages.logging.description}}",
                  "value": "login-activity-logging"
                },
                "enable": {
                  "setting": "enabled",
                  "label": "{{messages.logging.enabled}}"
                },
                "children": [
                  {
                    "type": "number-input",
                    "props": {
                      "name": "retentionDays",
                      "label": "{{messages.logging.retentionDays}}",
                      "min": 1,
                      "max": 365
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
