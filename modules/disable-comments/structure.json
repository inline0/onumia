{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "field",
        "props": {
          "label": "{{messages.title}}",
          "description": "{{messages.description}}",
          "value": "disable-comments"
        },
        "enable": {
          "setting": "enabled",
          "label": "{{messages.enable}}"
        },
        "children": [
          {
            "type": "entries",
            "props": {
              "name": "disableCommentsRules",
              "entry": "rules",
              "label": "{{messages.rules.label}}",
              "description": "{{messages.rules.description}}",
              "newLabel": "{{messages.rules.new}}",
              "surface": "inline",
              "search": true,
              "filters": true,
              "pagination": {
                "pageSize": 10,
                "pageSizeOptions": [10, 20, 50]
              },
              "sorting": {
                "default": {
                  "key": "label",
                  "direction": "asc"
                }
              },
              "columns": [
                {
                  "key": "label",
                  "label": "{{messages.columns.label}}"
                },
                {
                  "key": "enabledLabel",
                  "label": "{{messages.columns.enabled}}"
                },
                {
                  "key": "matchTypeLabel",
                  "label": "{{messages.columns.matchType}}"
                },
                {
                  "key": "matchPattern",
                  "label": "{{messages.columns.pattern}}"
                },
                {
                  "key": "policyLabel",
                  "label": "{{messages.columns.policy}}"
                }
              ],
              "createDrawer": {
                "side": "right",
                "size": "lg",
                "description": "{{messages.rules.createDescription}}"
              },
              "editDrawer": {
                "side": "right",
                "size": "lg",
                "description": "{{messages.rules.editDescription}}"
              }
            }
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
