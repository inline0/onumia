{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "entries",
        "props": {
          "name": "adminMenuRoles",
          "entry": "roles",
          "label": "{{messages.roles.label}}",
          "description": "{{messages.roles.description}}",
          "surface": "inline",
          "search": true,
          "filters": true,
          "edit": {
            "enabled": true,
            "submit": false
          },
          "pagination": {
            "pageSize": 10,
            "pageSizeOptions": [10, 20, 50]
          },
          "sorting": {
            "default": {
              "key": "label",
              "direction": "asc"
            }
          },
          "columns": [
            {
              "key": "label",
              "label": "{{messages.columns.role}}"
            },
            {
              "key": "hiddenCount",
              "label": "{{messages.columns.hidden}}"
            },
            {
              "key": "reorderedCount",
              "label": "{{messages.columns.reordered}}"
            },
            {
              "key": "lastEditedLabel",
              "label": "{{messages.columns.lastEdited}}"
            }
          ],
          "editDrawer": {
            "side": "right",
            "size": "lg",
            "description": "{{messages.roles.drawerDescription}}"
          }
        }
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
