{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "field",
        "props": {
          "label": "{{messages.rules.label}}",
          "description": "{{messages.rules.description}}",
          "value": "redirect-rules"
        },
        "enable": {
          "setting": "enabled",
          "label": "{{messages.rules.enable}}"
        },
        "children": [
          {
            "type": "entries",
            "props": {
              "name": "redirectRules",
              "entry": "rules",
              "surface": "inline",
              "search": true,
              "filters": true,
              "pagination": {
                "pageSize": 10,
                "pageSizeOptions": [10, 20, 50]
              },
              "sorting": {
                "default": {
                  "key": "hits",
                  "direction": "desc"
                }
              },
              "columns": [
                {
                  "key": "label",
                  "label": "{{messages.columns.label}}"
                },
                {
                  "key": "fromPattern",
                  "label": "{{messages.columns.from}}"
                },
                {
                  "key": "toUrl",
                  "label": "{{messages.columns.to}}"
                },
                {
                  "key": "statusCode",
                  "label": "{{messages.columns.status}}"
                },
                {
                  "key": "hits",
                  "label": "{{messages.columns.hits}}"
                },
                {
                  "key": "lastHitLabel",
                  "label": "{{messages.columns.lastHit}}"
                },
                {
                  "key": "enabledLabel",
                  "label": "{{messages.columns.enabled}}"
                }
              ],
              "editDrawer": {
                "side": "right",
                "size": "lg",
                "description": "{{messages.rules.drawerDescription}}"
              }
            }
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
