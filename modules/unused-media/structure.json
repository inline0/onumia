{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "tabs",
        "props": {
          "name": "unusedMediaTab",
          "defaultValue": "unused"
        },
        "children": [
          {
            "type": "tab",
            "props": {
              "value": "unused",
              "label": "{{messages.tabs.unused}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "unusedMediaEntries",
                  "entry": "scanResults",
                  "label": "{{messages.unused.label}}",
                  "description": "{{messages.unused.description}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "delete": {
                    "label": "{{messages.unused.deleteLabel}}",
                    "confirmTitle": "{{messages.unused.deleteTitle}}",
                    "confirmDescription": "{{messages.unused.deleteDescription}}",
                    "confirmLabel": "{{messages.unused.deleteConfirm}}"
                  },
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "sizeBytes",
                      "direction": "desc"
                    }
                  },
                  "columns": [
                    {
                      "key": "attachmentId",
                      "label": "{{messages.columns.attachmentId}}"
                    },
                    {
                      "key": "filename",
                      "label": "{{messages.columns.filename}}"
                    },
                    {
                      "key": "sizeLabel",
                      "label": "{{messages.columns.size}}"
                    },
                    {
                      "key": "mimeType",
                      "label": "{{messages.columns.mimeType}}"
                    },
                    {
                      "key": "uploadedLabel",
                      "label": "{{messages.columns.uploaded}}"
                    },
                    {
                      "key": "scannedLabel",
                      "label": "{{messages.columns.lastScan}}"
                    }
                  ],
                  "editDrawer": {
                    "side": "right",
                    "size": "md",
                    "description": "{{messages.unused.drawerDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "pending",
              "label": "{{messages.tabs.pending}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "pendingMediaEntries",
                  "entry": "pendingDeletions",
                  "label": "{{messages.pending.label}}",
                  "description": "{{messages.pending.description}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "delete": {
                    "label": "{{messages.pending.deleteLabel}}",
                    "confirmTitle": "{{messages.pending.deleteTitle}}",
                    "confirmDescription": "{{messages.pending.deleteDescription}}",
                    "confirmLabel": "{{messages.pending.deleteConfirm}}"
                  },
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "deletesAt",
                      "direction": "asc"
                    }
                  },
                  "columns": [
                    {
                      "key": "attachmentId",
                      "label": "{{messages.columns.attachmentId}}"
                    },
                    {
                      "key": "filename",
                      "label": "{{messages.columns.filename}}"
                    },
                    {
                      "key": "queuedAtLabel",
                      "label": "{{messages.columns.queuedAt}}"
                    },
                    {
                      "key": "deletesAtLabel",
                      "label": "{{messages.columns.deletesAt}}"
                    },
                    {
                      "key": "queuedByLabel",
                      "label": "{{messages.columns.queuedBy}}"
                    }
                  ],
                  "editDrawer": {
                    "side": "right",
                    "size": "md",
                    "description": "{{messages.pending.drawerDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "settings",
              "label": "{{messages.tabs.settings}}"
            },
            "children": [
              {
                "type": "field",
                "props": {
                  "label": "{{messages.settings.scan.label}}",
                  "description": "{{messages.settings.scan.description}}",
                  "value": "unused-media-scan"
                },
                "enable": {
                  "setting": "enabled",
                  "label": "{{messages.settings.scan.enabled}}"
                },
                "children": [
                  {
                    "type": "select",
                    "props": {
                      "name": "scanFrequency",
                      "label": "{{messages.settings.scan.frequency}}",
                      "options": [
                        {
                          "value": "daily",
                          "label": "{{messages.frequency.daily}}"
                        },
                        {
                          "value": "weekly",
                          "label": "{{messages.frequency.weekly}}"
                        },
                        {
                          "value": "manual",
                          "label": "{{messages.frequency.manual}}"
                        }
                      ]
                    }
                  },
                  {
                    "type": "button",
                    "props": {
                      "label": "{{messages.settings.scan.runNow}}",
                      "variant": "outline"
                    },
                    "events": {
                      "click": {
                        "event": "unusedMedia.runScan"
                      }
                    }
                  },
                  {
                    "type": "preview",
                    "props": {
                      "name": "unusedMediaScan",
                      "text": "{{messages.settings.scan.result}}"
                    }
                  }
                ]
              },
              {
                "type": "field",
                "props": {
                  "label": "{{messages.settings.safety.label}}",
                  "description": "{{messages.settings.safety.description}}",
                  "value": "unused-media-safety"
                },
                "children": [
                  {
                    "type": "number-input",
                    "props": {
                      "name": "pendingWindowDays",
                      "label": "{{messages.settings.safety.pendingWindowDays}}",
                      "min": 1,
                      "max": 90
                    }
                  },
                  {
                    "type": "repeater",
                    "props": {
                      "name": "excludeAttachmentIds",
                      "label": "{{messages.settings.safety.excludeAttachmentIds}}",
                      "itemLabel": "{{messages.settings.safety.excludeAttachmentId}}"
                    },
                    "children": [
                      {
                        "type": "number-input",
                        "props": {
                          "name": "value",
                          "label": "{{messages.settings.safety.excludeAttachmentId}}",
                          "min": 1
                        }
                      }
                    ]
                  },
                  {
                    "type": "multi-select",
                    "props": {
                      "name": "excludeMimeTypes",
                      "label": "{{messages.settings.safety.excludeMimeTypes}}",
                      "optionsSource": {
                        "source": "wp.mime.types"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": [
        {
          "event": "unusedMedia.runScan",
          "target": "settings",
          "effects": [
            {
              "type": "action",
              "action": "runScanNow",
              "target": "unusedMediaScan"
            }
          ]
        }
      ]
    }
  ]
}
