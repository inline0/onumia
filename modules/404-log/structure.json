{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "tabs",
        "props": {
          "name": "fourOhFourLogTab",
          "defaultValue": "hits"
        },
        "children": [
          {
            "type": "tab",
            "props": {
              "value": "hits",
              "label": "{{messages.tabs.hits}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "fourOhFourLogHits",
                  "entry": "fourOhFourLogHits",
                  "label": "{{messages.hits.label}}",
                  "description": "{{messages.hits.description}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "lastSeenAt",
                      "direction": "desc"
                    }
                  },
                  "columns": [
                    {
                      "key": "urlPreview",
                      "label": "{{messages.columns.url}}"
                    },
                    {
                      "key": "count",
                      "label": "{{messages.columns.count}}"
                    },
                    {
                      "key": "firstSeenLabel",
                      "label": "{{messages.columns.firstSeen}}"
                    },
                    {
                      "key": "lastSeenLabel",
                      "label": "{{messages.columns.lastSeen}}"
                    },
                    {
                      "key": "lastReferrerPreview",
                      "label": "{{messages.columns.referrer}}"
                    }
                  ],
                  "bulkActions": [
                    {
                      "action": "createRedirectFromSelected",
                      "label": "{{messages.hits.createRedirect}}",
                      "variant": "outline"
                    }
                  ],
                  "editDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.hits.drawerDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "settings",
              "label": "{{messages.tabs.settings}}"
            },
            "children": [
              {
                "type": "field",
                "props": {
                  "label": "{{messages.capture.label}}",
                  "description": "{{messages.capture.description}}",
                  "value": "four-oh-four-log-capture"
                },
                "enable": {
                  "setting": "enabled",
                  "label": "{{messages.capture.enabled}}"
                },
                "children": [
                  {
                    "type": "number-input",
                    "props": {
                      "name": "retentionDays",
                      "label": "{{messages.capture.retentionDays}}",
                      "min": 1,
                      "max": 365
                    }
                  },
                  {
                    "type": "repeater",
                    "props": {
                      "name": "ignoredPatterns",
                      "label": "{{messages.capture.ignoredPatterns}}",
                      "itemLabel": "{{messages.capture.ignoredPatternItem}}"
                    },
                    "children": [
                      {
                        "type": "text-input",
                        "props": {
                          "name": "value",
                          "label": "{{messages.capture.ignoredPatternItem}}"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
