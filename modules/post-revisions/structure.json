{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "field",
        "props": {
          "label": "{{messages.title}}",
          "description": "{{messages.description}}",
          "value": "post-revisions"
        },
        "enable": {
          "setting": "enabled",
          "label": "{{messages.enable}}"
        },
        "children": [
          {
            "type": "tabs",
            "props": {
              "name": "postRevisionsTab",
              "defaultValue": "rules"
            },
            "children": [
              {
                "type": "tab",
                "props": {
                  "value": "rules",
                  "label": "{{messages.tabs.rules}}"
                },
                "children": [
                  {
                    "type": "field",
                    "props": {
                      "label": "{{messages.rules.manual.label}}",
                      "description": "{{messages.rules.manual.description}}",
                      "value": "post-revisions-manual"
                    },
                    "children": [
                      {
                        "type": "button",
                        "props": {
                          "label": "{{messages.rules.manual.runPruneNow}}",
                          "variant": "outline"
                        },
                        "events": {
                          "click": {
                            "event": "postRevisions.runPrune"
                          }
                        }
                      },
                      {
                        "type": "preview",
                        "props": {
                          "name": "postRevisionPrune",
                          "text": "{{messages.rules.manual.pruneResult}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "entries",
                    "props": {
                      "name": "postRevisionRules",
                      "entry": "rules",
                      "label": "{{messages.rules.label}}",
                      "description": "{{messages.rules.description}}",
                      "surface": "inline",
                      "search": true,
                      "filters": true,
                      "pagination": {
                        "pageSize": 10,
                        "pageSizeOptions": [10, 20, 50]
                      },
                      "sorting": {
                        "default": {
                          "key": "label",
                          "direction": "asc"
                        }
                      },
                      "columns": [
                        {
                          "key": "label",
                          "label": "{{messages.columns.postType}}"
                        },
                        {
                          "key": "maxRevisionsLabel",
                          "label": "{{messages.columns.maxRevisions}}"
                        },
                        {
                          "key": "maxAgeDaysLabel",
                          "label": "{{messages.columns.maxAgeDays}}"
                        },
                        {
                          "key": "enabledLabel",
                          "label": "{{messages.columns.enabled}}"
                        },
                        {
                          "key": "currentRevisionCount",
                          "label": "{{messages.columns.currentRevisionCount}}"
                        }
                      ],
                      "editDrawer": {
                        "side": "right",
                        "size": "md",
                        "description": "{{messages.rules.drawerDescription}}"
                      }
                    }
                  }
                ]
              },
              {
                "type": "tab",
                "props": {
                  "value": "log",
                  "label": "{{messages.tabs.log}}"
                },
                "children": [
                  {
                    "type": "entries",
                    "props": {
                      "name": "postRevisionPruneLog",
                      "entry": "pruneLog",
                      "label": "{{messages.log.label}}",
                      "description": "{{messages.log.description}}",
                      "surface": "inline",
                      "search": true,
                      "filters": true,
                      "pagination": {
                        "pageSize": 10,
                        "pageSizeOptions": [10, 20, 50]
                      },
                      "sorting": {
                        "default": {
                          "key": "prunedAt",
                          "direction": "desc"
                        }
                      },
                      "columns": [
                        {
                          "key": "prunedAtLabel",
                          "label": "{{messages.columns.prunedAt}}"
                        },
                        {
                          "key": "postType",
                          "label": "{{messages.columns.postType}}"
                        },
                        {
                          "key": "postId",
                          "label": "{{messages.columns.postId}}"
                        },
                        {
                          "key": "reasonLabel",
                          "label": "{{messages.columns.reason}}"
                        },
                        {
                          "key": "revisionsRemoved",
                          "label": "{{messages.columns.revisionsRemoved}}"
                        }
                      ],
                      "editDrawer": {
                        "side": "right",
                        "size": "md",
                        "description": "{{messages.log.drawerDescription}}"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": [
        {
          "event": "postRevisions.runPrune",
          "target": "settings",
          "effects": [
            {
              "type": "action",
              "action": "runPrune",
              "target": "postRevisionPrune"
            }
          ]
        }
      ]
    }
  ]
}
