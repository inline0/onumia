{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "tabs",
        "props": {
          "name": "userApprovalTab",
          "defaultValue": "pending"
        },
        "children": [
          {
            "type": "tab",
            "props": {
              "value": "pending",
              "label": "{{messages.tabs.pending}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "pendingUsersEntries",
                  "entry": "pendingUsers",
                  "label": "{{messages.pending.label}}",
                  "description": "{{messages.pending.description}}",
                  "emptyMessage": "{{messages.pending.empty}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "registeredAt",
                      "direction": "desc"
                    }
                  },
                  "columns": [
                    {
                      "key": "userLogin",
                      "label": "{{messages.columns.username}}"
                    },
                    {
                      "key": "email",
                      "label": "{{messages.columns.email}}"
                    },
                    {
                      "key": "registeredLabel",
                      "label": "{{messages.columns.registered}}"
                    },
                    {
                      "key": "requestedRoleLabel",
                      "label": "{{messages.columns.requestedRole}}"
                    }
                  ],
                  "bulkActions": [
                    {
                      "action": "approveUsers",
                      "label": "{{messages.pending.approveSelected}}",
                      "variant": "outline"
                    }
                  ],
                  "rowActions": [
                    {
                      "action": "approveUsers",
                      "label": "{{messages.pending.approve}}",
                      "variant": "outline"
                    },
                    {
                      "action": "rejectUsers",
                      "label": "{{messages.pending.reject}}",
                      "variant": "destructive"
                    }
                  ],
                  "delete": {
                    "label": "{{messages.pending.rejectSelected}}",
                    "confirmTitle": "{{messages.pending.rejectTitle}}",
                    "confirmDescription": "{{messages.pending.rejectDescription}}",
                    "confirmLabel": "{{messages.pending.rejectConfirm}}"
                  },
                  "editDrawer": {
                    "side": "right",
                    "size": "md",
                    "description": "{{messages.pending.drawerDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "settings",
              "label": "{{messages.tabs.settings}}"
            },
            "children": [
              {
                "type": "field",
                "props": {
                  "label": "{{messages.approval.label}}",
                  "description": "{{messages.approval.description}}",
                  "value": "user-approval-policy"
                },
                "enable": {
                  "setting": "enabled",
                  "label": "{{messages.approval.enabled}}"
                },
                "children": [
                  {
                    "type": "select",
                    "props": {
                      "name": "defaultRoleOnApproval",
                      "label": "{{messages.approval.defaultRole}}",
                      "optionsSource": {
                        "source": "wp.user.roles"
                      }
                    }
                  },
                  {
                    "type": "repeater",
                    "props": {
                      "name": "autoApproveDomains",
                      "label": "{{messages.approval.autoDomains}}",
                      "itemLabel": "{{messages.approval.autoDomain}}"
                    },
                    "children": [
                      {
                        "type": "text-input",
                        "props": {
                          "name": "value",
                          "label": "{{messages.approval.autoDomain}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "switch",
                    "props": {
                      "name": "notifyUserOnApproval",
                      "label": "{{messages.approval.notifyApproval}}"
                    }
                  },
                  {
                    "type": "switch",
                    "props": {
                      "name": "notifyUserOnRejection",
                      "label": "{{messages.approval.notifyRejection}}"
                    }
                  },
                  {
                    "type": "switch",
                    "props": {
                      "name": "deleteOnRejection",
                      "label": "{{messages.approval.deleteOnRejection}}"
                    }
                  },
                  {
                    "type": "switch",
                    "props": {
                      "name": "notifyAdminOnPending",
                      "label": "{{messages.approval.notifyAdmin}}"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
