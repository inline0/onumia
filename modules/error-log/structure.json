{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "tabs",
        "props": {
          "name": "errorLogTab",
          "defaultValue": "errors"
        },
        "children": [
          {
            "type": "tab",
            "props": {
              "value": "errors",
              "label": "{{messages.tabs.errors}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "errorLogEntries",
                  "entry": "errors",
                  "label": "{{messages.errors.label}}",
                  "description": "{{messages.errors.description}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "lastSeenAt",
                      "direction": "desc"
                    }
                  },
                  "columns": [
                    {
                      "key": "lastSeenLabel",
                      "label": "{{messages.columns.lastSeen}}"
                    },
                    {
                      "key": "severityLabel",
                      "label": "{{messages.columns.severity}}"
                    },
                    {
                      "key": "messagePreview",
                      "label": "{{messages.columns.message}}"
                    },
                    {
                      "key": "location",
                      "label": "{{messages.columns.location}}"
                    },
                    {
                      "key": "count",
                      "label": "{{messages.columns.count}}"
                    }
                  ],
                  "editDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.errors.drawerDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "settings",
              "label": "{{messages.tabs.settings}}"
            },
            "children": [
              {
                "type": "field",
                "props": {
                  "label": "{{messages.capture.label}}",
                  "description": "{{messages.capture.description}}",
                  "value": "error-log-capture"
                },
                "enable": {
                  "setting": "enabled",
                  "label": "{{messages.capture.enabled}}"
                },
                "children": [
                  {
                    "type": "select",
                    "props": {
                      "name": "severityThreshold",
                      "label": "{{messages.capture.severityThreshold}}",
                      "options": [
                        {
                          "value": "notice",
                          "label": "{{messages.severities.notice}}"
                        },
                        {
                          "value": "warning",
                          "label": "{{messages.severities.warning}}"
                        },
                        {
                          "value": "error",
                          "label": "{{messages.severities.error}}"
                        }
                      ]
                    }
                  },
                  {
                    "type": "switch",
                    "props": {
                      "name": "captureDeprecated",
                      "label": "{{messages.capture.captureDeprecated}}"
                    }
                  },
                  {
                    "type": "number-input",
                    "props": {
                      "name": "retentionDays",
                      "label": "{{messages.capture.retentionDays}}",
                      "min": 1,
                      "max": 365
                    }
                  },
                  {
                    "type": "repeater",
                    "props": {
                      "name": "ignoredPatterns",
                      "label": "{{messages.capture.ignoredPatterns}}",
                      "itemLabel": "{{messages.capture.ignoredPatternItem}}"
                    },
                    "children": [
                      {
                        "type": "text-input",
                        "props": {
                          "name": "value",
                          "label": "{{messages.capture.ignoredPatternItem}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "button",
                    "props": {
                      "label": "{{messages.capture.triggerTestError}}",
                      "variant": "outline"
                    },
                    "help": {
                      "text": "{{messages.capture.triggerTestErrorHelp}}"
                    },
                    "events": {
                      "click": {
                        "event": "errorLog.triggerTestError"
                      }
                    }
                  },
                  {
                    "type": "preview",
                    "props": {
                      "name": "errorTestCapture",
                      "text": "{{messages.capture.testErrorResult}}"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": [
        {
          "event": "errorLog.triggerTestError",
          "target": "settings",
          "effects": [
            {
              "type": "action",
              "action": "triggerTestError",
              "target": "errorTestCapture"
            }
          ]
        }
      ]
    }
  ]
}
