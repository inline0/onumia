{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "tabs",
        "props": {
          "name": "dashboardWidgetsTab",
          "defaultValue": "per-role"
        },
        "children": [
          {
            "type": "tab",
            "props": {
              "value": "per-role",
              "label": "{{messages.tabs.perRole}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "dashboardWidgetRoles",
                  "entry": "roleVisibility",
                  "label": "{{messages.perRole.label}}",
                  "description": "{{messages.perRole.description}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "label",
                      "direction": "asc"
                    }
                  },
                  "columns": [
                    {
                      "key": "label",
                      "label": "{{messages.columns.role}}"
                    },
                    {
                      "key": "visibleCount",
                      "label": "{{messages.columns.visible}}"
                    },
                    {
                      "key": "hiddenCount",
                      "label": "{{messages.columns.hidden}}"
                    }
                  ],
                  "editDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.perRole.drawerDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "custom",
              "label": "{{messages.tabs.custom}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "dashboardCustomWidgets",
                  "entry": "customWidgets",
                  "label": "{{messages.custom.label}}",
                  "description": "{{messages.custom.description}}",
                  "newLabel": "{{messages.custom.new}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [10, 20, 50]
                  },
                  "sorting": {
                    "default": {
                      "key": "order",
                      "direction": "asc"
                    }
                  },
                  "columns": [
                    {
                      "key": "title",
                      "label": "{{messages.columns.title}}"
                    },
                    {
                      "key": "enabledLabel",
                      "label": "{{messages.columns.enabled}}"
                    },
                    {
                      "key": "order",
                      "label": "{{messages.columns.order}}"
                    },
                    {
                      "key": "rolesLabel",
                      "label": "{{messages.columns.audience}}"
                    }
                  ],
                  "createDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.custom.createDescription}}"
                  },
                  "editDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.custom.editDescription}}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
