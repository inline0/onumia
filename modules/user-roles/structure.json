{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "field",
        "props": {
          "label": "{{messages.title}}",
          "description": "{{messages.description}}",
          "value": "user-roles"
        },
        "children": [
          {
            "type": "entries",
            "props": {
              "name": "userRolesEntries",
              "entry": "roles",
              "label": "{{messages.roles.label}}",
              "description": "{{messages.roles.description}}",
              "newLabel": "{{messages.roles.new}}",
              "surface": "inline",
              "search": true,
              "filters": true,
              "pagination": {
                "pageSize": 10,
                "pageSizeOptions": [10, 20, 50]
              },
              "sorting": {
                "default": {
                  "key": "label",
                  "direction": "asc"
                }
              },
              "columns": [
                {
                  "key": "label",
                  "label": "{{messages.columns.label}}"
                },
                {
                  "key": "slug",
                  "label": "{{messages.columns.slug}}"
                },
                {
                  "key": "originLabel",
                  "label": "{{messages.columns.origin}}"
                },
                {
                  "key": "userCount",
                  "label": "{{messages.columns.users}}"
                },
                {
                  "key": "capabilityCount",
                  "label": "{{messages.columns.capabilities}}"
                }
              ],
              "createDrawer": {
                "side": "right",
                "size": "lg",
                "description": "{{messages.drawer.createDescription}}"
              },
              "editDrawer": {
                "side": "right",
                "size": "lg",
                "description": "{{messages.drawer.editDescription}}"
              }
            }
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
