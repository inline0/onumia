{
  "$schema": "../../schemas/structure.json",
  "initialState": "settings",
  "views": {
    "settings": {
      "component": {
        "type": "tabs",
        "props": {
          "name": "loginBlockerTab",
          "defaultValue": "rules"
        },
        "children": [
          {
            "type": "tab",
            "props": {
              "value": "rules",
              "label": "{{messages.tabs.rules}}"
            },
            "children": [
              {
                "type": "field",
                "props": {
                  "label": "{{messages.policy.label}}",
                  "description": "{{messages.policy.description}}",
                  "value": "login-blocker-policy"
                },
                "enable": {
                  "setting": "enabled",
                  "label": "{{messages.policy.enabled}}"
                },
                "children": [
                  {
                    "type": "switch",
                    "props": {
                      "name": "throttle.enabled",
                      "label": "{{messages.policy.throttleEnabled}}"
                    }
                  },
                  {
                    "type": "number-input",
                    "props": {
                      "name": "throttle.windowMinutes",
                      "label": "{{messages.policy.windowMinutes}}",
                      "min": 1,
                      "max": 1440
                    }
                  },
                  {
                    "type": "number-input",
                    "props": {
                      "name": "throttle.maxAttempts",
                      "label": "{{messages.policy.maxAttempts}}",
                      "min": 1,
                      "max": 100
                    }
                  },
                  {
                    "type": "number-input",
                    "props": {
                      "name": "throttle.lockoutMinutes",
                      "label": "{{messages.policy.lockoutMinutes}}",
                      "min": 1,
                      "max": 10080
                    }
                  },
                  {
                    "type": "number-input",
                    "props": {
                      "name": "retentionDays",
                      "label": "{{messages.policy.retentionDays}}",
                      "min": 1,
                      "max": 365
                    }
                  },
                  {
                    "type": "repeater",
                    "props": {
                      "name": "whitelist.ips",
                      "label": "{{messages.policy.whitelistIps}}",
                      "itemLabel": "{{messages.policy.whitelistIpItem}}"
                    },
                    "children": [
                      {
                        "type": "text-input",
                        "props": {
                          "name": "value",
                          "label": "{{messages.policy.whitelistIpItem}}"
                        }
                      }
                    ]
                  },
                  {
                    "type": "repeater",
                    "props": {
                      "name": "whitelist.usernames",
                      "label": "{{messages.policy.whitelistUsernames}}",
                      "itemLabel": "{{messages.policy.whitelistUsernameItem}}"
                    },
                    "children": [
                      {
                        "type": "text-input",
                        "props": {
                          "name": "value",
                          "label": "{{messages.policy.whitelistUsernameItem}}"
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "entries",
                "props": {
                  "name": "loginBlockerRules",
                  "entry": "rules",
                  "label": "{{messages.rules.label}}",
                  "description": "{{messages.rules.description}}",
                  "newLabel": "{{messages.rules.new}}",
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [
                      10,
                      20,
                      50
                    ]
                  },
                  "sorting": {
                    "default": {
                      "key": "label",
                      "direction": "asc"
                    }
                  },
                  "columns": [
                    {
                      "key": "label",
                      "label": "{{messages.columns.label}}"
                    },
                    {
                      "key": "enabledLabel",
                      "label": "{{messages.columns.enabled}}"
                    },
                    {
                      "key": "matchTypeLabel",
                      "label": "{{messages.columns.matchType}}"
                    },
                    {
                      "key": "matchPattern",
                      "label": "{{messages.columns.pattern}}"
                    },
                    {
                      "key": "actionLabel",
                      "label": "{{messages.columns.action}}"
                    }
                  ],
                  "createDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.rules.createDescription}}"
                  },
                  "editDrawer": {
                    "side": "right",
                    "size": "lg",
                    "description": "{{messages.rules.editDescription}}"
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "attempts",
              "label": "{{messages.tabs.attempts}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "loginAttemptsEntries",
                  "entry": "loginAttempts",
                  "label": "{{messages.attempts.label}}",
                  "description": "{{messages.attempts.description}}",
                  "surface": "inline",
                  "delete": {
                    "label": "{{messages.attempts.blockSelected}}",
                    "confirmTitle": "{{messages.attempts.blockSelectedTitle}}",
                    "confirmDescription": "{{messages.attempts.blockSelectedDescription}}"
                  },
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [
                      10,
                      20,
                      50
                    ]
                  },
                  "sorting": {
                    "default": {
                      "key": "attemptedAt",
                      "direction": "desc"
                    }
                  }
                }
              }
            ]
          },
          {
            "type": "tab",
            "props": {
              "value": "lockouts",
              "label": "{{messages.tabs.lockouts}}"
            },
            "children": [
              {
                "type": "entries",
                "props": {
                  "name": "activeLockoutsEntries",
                  "entry": "activeLockouts",
                  "label": "{{messages.lockouts.label}}",
                  "description": "{{messages.lockouts.description}}",
                  "delete": {
                    "label": "{{messages.lockouts.unlock}}",
                    "confirmTitle": "{{messages.lockouts.unlockTitle}}",
                    "confirmDescription": "{{messages.lockouts.unlockDescription}}"
                  },
                  "surface": "inline",
                  "search": true,
                  "filters": true,
                  "pagination": {
                    "pageSize": 10,
                    "pageSizeOptions": [
                      10,
                      20,
                      50
                    ]
                  },
                  "sorting": {
                    "default": {
                      "key": "expiresAt",
                      "direction": "asc"
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    }
  },
  "states": [
    {
      "name": "settings",
      "view": "settings",
      "transitions": []
    }
  ]
}
