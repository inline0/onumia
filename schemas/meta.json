{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onumia.local/schemas/meta.json",
  "title": "Onumia Module Metadata",
  "description": "Schema for a Onumia module meta.json file.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)+$"
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "devOnly": {
      "type": "boolean"
    },
    "releaseEnabled": {
      "type": "boolean"
    },
    "releaseReason": {
      "type": "string"
    }
  },
  "required": ["name", "category", "label", "version"],
  "additionalProperties": false
}
