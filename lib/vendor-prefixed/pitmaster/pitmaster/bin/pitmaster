#!/usr/bin/env php
<?php

declare(strict_types=1);

ini_set('memory_limit', '512M');

require dirname(__DIR__) . '/vendor/autoload.php';

use Pitmaster\Diff\ColorDiff;
use Pitmaster\Pitmaster;
use Pitmaster\Ref\Reflog;
use Pitmaster\Repository;

$arguments = array_slice($argv, 1);

if ($arguments === []) {
    fwrite(STDERR, "Usage: pitmaster <command> [args...]\n\n");
    fwrite(STDERR, "Commands:\n");
    fwrite(STDERR, "  log [--all] [--oneline] [path] [N]  Show commit history (default 10)\n");
    fwrite(STDERR, "  show <rev>          Show commit details + diff\n");
    fwrite(STDERR, "  cat-file <hash>     Print object content\n");
    fwrite(STDERR, "  status              Show working tree status\n");
    fwrite(STDERR, "  diff                Show unstaged changes\n");
    fwrite(STDERR, "  diff --cached       Show staged changes\n");
    fwrite(STDERR, "  add <file...>       Stage files\n");
    fwrite(STDERR, "  commit [-m <msg>]   Create a commit\n");
    fwrite(STDERR, "  branch [name]       List or create branches\n");
    fwrite(STDERR, "  tag [name] [-m]     List or create tags\n");
    fwrite(STDERR, "  checkout <ref>      Switch branches or detach HEAD\n");
    fwrite(STDERR, "  merge <branch...>   Merge branches into HEAD\n");
    fwrite(STDERR, "  merge --continue    Continue an in-progress merge\n");
    fwrite(STDERR, "  merge --abort       Abort an in-progress merge\n");
    fwrite(STDERR, "  bisect start <bad> <good>  Start bisect session\n");
    fwrite(STDERR, "  bisect good [rev]   Mark current or given rev as good\n");
    fwrite(STDERR, "  bisect bad [rev]    Mark current or given rev as bad\n");
    fwrite(STDERR, "  bisect reset        Reset bisect session\n");
    fwrite(STDERR, "  cherry-pick <rev>   Cherry-pick a commit onto HEAD\n");
    fwrite(STDERR, "  cherry-pick --continue  Continue an in-progress cherry-pick\n");
    fwrite(STDERR, "  cherry-pick --abort     Abort an in-progress cherry-pick\n");
    fwrite(STDERR, "  revert <rev>        Revert a commit on HEAD\n");
    fwrite(STDERR, "  revert --continue   Continue an in-progress revert\n");
    fwrite(STDERR, "  revert --abort      Abort an in-progress revert\n");
    fwrite(STDERR, "  rebase <ref>        Rebase HEAD onto another ref\n");
    fwrite(STDERR, "  rebase --continue   Continue an in-progress rebase\n");
    fwrite(STDERR, "  rebase --abort      Abort an in-progress rebase\n");
    fwrite(STDERR, "  rebase --skip       Skip the current rebase commit\n");
    fwrite(STDERR, "  stash [pop|list]    Stash working directory changes\n");
    fwrite(STDERR, "  blame <file>        Show line-by-line authorship\n");
    fwrite(STDERR, "  grep [-i] [-E] <pattern>  Search file contents\n");
    fwrite(STDERR, "  reflog [show <ref>] [--format=<fmt>] [-n <N>]  Show reflog entries\n");
    fwrite(STDERR, "  refs                List all refs\n");
    fwrite(STDERR, "  init [path] [--object-format=<sha1|sha256>]  Initialize a new repository\n");
    exit(1);
}

$command = array_shift($arguments);

// Commands that don't need an existing repo
if ($command === 'init') {
    $path = getcwd();
    $objectFormat = 'sha1';

    foreach ($arguments as $arg) {
        if (str_starts_with($arg, '--object-format=')) {
            $objectFormat = substr($arg, 16);
            continue;
        }

        $path = $arg;
    }

    Pitmaster::init($path, $objectFormat);
    fwrite(STDOUT, "Initialized empty Pitmaster repository in {$path}/.git/\n");
    exit(0);
}

$repoPath = getcwd();

try {
    $repo = Pitmaster::open($repoPath);
} catch (\Throwable $e) {
    fwrite(STDERR, "fatal: {$e->getMessage()}\n");
    exit(128);
}

try {
    match ($command) {
        'log' => commandLog($repo, $arguments),
        'show' => commandShow($repo, $arguments),
        'cat-file' => commandCatFile($repo, $arguments),
        'status' => commandStatus($repo, $arguments),
        'diff' => commandDiff($repo, $arguments),
        'add' => commandAdd($repo, $arguments),
        'commit' => commandCommit($repo, $arguments),
        'branch' => commandBranch($repo, $arguments),
        'tag' => commandTag($repo, $arguments),
        'checkout' => commandCheckout($repo, $arguments),
        'merge' => commandMerge($repo, $arguments),
        'bisect' => commandBisect($repo, $arguments),
        'cherry-pick' => commandCherryPick($repo, $arguments),
        'revert' => commandRevert($repo, $arguments),
        'rebase' => commandRebase($repo, $arguments),
        'stash' => commandStash($repo, $arguments),
        'blame' => commandBlame($repo, $arguments),
        'grep' => commandGrep($repo, $arguments),
        'reflog' => commandReflog($repo, $arguments),
        'refs' => commandRefs($repo),
        'reset' => commandReset($repo, $arguments),
        default => (function () use ($command) {
            fwrite(STDERR, "pitmaster: '{$command}' is not a command.\n");
            exit(1);
        })(),
    };
} catch (\Throwable $e) {
    fwrite(STDERR, "error: {$e->getMessage()}\n");
    exit(1);
}

function commandLog(Repository $repo, array $args): void
{
    $limit = 10;
    $all = false;
    $oneline = false;
    $path = null;

    foreach ($args as $arg) {
        if ($arg === '--all') {
            $all = true;
            continue;
        }

        if ($arg === '--oneline') {
            $oneline = true;
            continue;
        }

        if (is_numeric($arg)) {
            $limit = (int) $arg;
            continue;
        }

        if ($path === null) {
            $path = $arg;
        }
    }

    if ($oneline) {
        foreach ($repo->logOneline($limit, $all, $path) as $line) {
            fwrite(STDOUT, "{$line}\n");
        }

        return;
    }

    $commits = $path !== null
        ? $repo->logPath($path, $limit)
        : ($all ? $repo->logAll($limit) : $repo->log($limit));

    foreach ($commits as $commit) {
        fwrite(STDOUT, "\033[33mcommit {$commit->id->hex}\033[0m\n");

        if ($commit->isMerge()) {
            $parentHexes = array_map(fn ($p) => substr($p->hex, 0, 7), $commit->parents);
            fwrite(STDOUT, "Merge: " . implode(' ', $parentHexes) . "\n");
        }

        fwrite(STDOUT, "Author: {$commit->author}\n\n");

        foreach (explode("\n", trim($commit->message)) as $line) {
            fwrite(STDOUT, "    {$line}\n");
        }

        fwrite(STDOUT, "\n");
    }
}

function commandShow(Repository $repo, array $args): void
{
    $rev = $args[0] ?? 'HEAD';
    $result = $repo->show($rev);
    $commit = $result['commit'];
    $color = outputSupportsColor();

    if (isset($result['tag'])) {
        $tag = $result['tag'];
        fwrite(STDOUT, decorateHeader("tag {$tag->name}", $color));
        fwrite(STDOUT, "Tagger: " . identityPerson($tag->tagger) . "\n");
        fwrite(STDOUT, "Date:   " . identityDate($tag->tagger) . "\n\n");
        fwrite(STDOUT, rtrim($tag->message, "\n") . "\n\n");
    }

    fwrite(STDOUT, decorateHeader("commit {$commit->id->hex}", $color));

    if ($commit->isMerge()) {
        $parentHexes = array_map(static fn ($parent) => substr($parent->hex, 0, 7), $commit->parents);
        fwrite(STDOUT, "Merge: " . implode(' ', $parentHexes) . "\n");
    }

    fwrite(STDOUT, "Author: " . identityPerson($commit->author) . "\n");
    fwrite(STDOUT, "Date:   " . identityDate($commit->author) . "\n\n");
    fwrite(STDOUT, indentMessage($commit->message));

    if (!$commit->isMerge()) {
        foreach ($result['diff'] as $diff) {
            $formatted = $diff->format();
            fwrite(STDOUT, $color ? ColorDiff::colorize($formatted) : $formatted);
        }
    }
}

function outputSupportsColor(): bool
{
    return function_exists('stream_isatty') && stream_isatty(STDOUT);
}

function decorateHeader(string $header, bool $color): string
{
    if (!$color) {
        return $header . "\n";
    }

    return "\033[33m{$header}\033[0m\n";
}

function identityPerson(string $identity): string
{
    if (preg_match('/^(.* <.*>) \d+ [+-]\d{4}$/', $identity, $matches) === 1) {
        return $matches[1];
    }

    return $identity;
}

function identityDate(string $identity): string
{
    if (preg_match('/^.* <.*> (\d+) ([+-]\d{4})$/', $identity, $matches) !== 1) {
        return $identity;
    }

    $date = \DateTimeImmutable::createFromFormat('U', $matches[1]);

    if ($date === false) {
        return $identity;
    }

    try {
        $date = $date->setTimezone(new \DateTimeZone($matches[2]));
    } catch (\Exception) {
        return $identity;
    }

    return $date->format('D M j H:i:s Y O');
}

function indentMessage(string $message): string
{
    $trimmed = trim($message);

    if ($trimmed === '') {
        return "\n";
    }

    $lines = explode("\n", $trimmed);
    $output = '';

    foreach ($lines as $line) {
        $output .= "    {$line}\n";
    }

    return $output . "\n";
}

function commandCatFile(Repository $repo, array $args): void
{
    if (!isset($args[0])) {
        fwrite(STDERR, "Usage: pitmaster cat-file <hash>\n");
        exit(1);
    }

    fwrite(STDOUT, $repo->catFile($args[0]));
}

function commandStatus(Repository $repo, array $args): void
{
    if (in_array('--porcelain=v2', $args, true)) {
        fwrite(STDOUT, $repo->statusPorcelainV2());
        return;
    }

    $branch = $repo->branch();

    if ($branch !== null) {
        fwrite(STDOUT, "On branch {$branch}\n");
    } else {
        fwrite(STDOUT, "HEAD detached\n");
    }

    $entries = $repo->status();

    if ($entries === []) {
        fwrite(STDOUT, "nothing to commit, working tree clean\n");
        return;
    }

    $staged = [];
    $unstaged = [];
    $untracked = [];
    $unmerged = [];

    foreach ($entries as $entry) {
        if ($entry->index === \Pitmaster\Status\FileStatus::Untracked) {
            $untracked[] = $entry;
        } elseif (
            $entry->index === \Pitmaster\Status\FileStatus::Unmerged
            || $entry->worktree === \Pitmaster\Status\FileStatus::Unmerged
        ) {
            $unmerged[] = $entry;
        } elseif ($entry->index !== \Pitmaster\Status\FileStatus::Unmodified) {
            $staged[] = $entry;
        }

        if ($entry->worktree !== \Pitmaster\Status\FileStatus::Unmodified
            && $entry->worktree !== \Pitmaster\Status\FileStatus::Unmerged
            && $entry->index !== \Pitmaster\Status\FileStatus::Untracked
            && $entry->index !== \Pitmaster\Status\FileStatus::Unmerged
        ) {
            $unstaged[] = $entry;
        }
    }

    if ($unmerged !== []) {
        fwrite(STDOUT, "\nUnmerged paths:\n");

        foreach ($unmerged as $entry) {
            fwrite(STDOUT, "\t\033[31munmerged:   {$entry->path}\033[0m\n");
        }
    }

    if ($staged !== []) {
        fwrite(STDOUT, "\nChanges to be committed:\n");

        foreach ($staged as $entry) {
            $action = match ($entry->index) {
                \Pitmaster\Status\FileStatus::Added => 'new file',
                \Pitmaster\Status\FileStatus::Modified => 'modified',
                \Pitmaster\Status\FileStatus::Deleted => 'deleted',
                \Pitmaster\Status\FileStatus::Renamed => 'renamed',
                default => $entry->index->value,
            };
            $pathLabel = $entry->index === \Pitmaster\Status\FileStatus::Renamed && $entry->origPath !== null
                ? "{$entry->origPath} -> {$entry->path}"
                : $entry->path;
            fwrite(STDOUT, "\t\033[32m{$action}:   {$pathLabel}\033[0m\n");
        }
    }

    if ($unstaged !== []) {
        fwrite(STDOUT, "\nChanges not staged for commit:\n");

        foreach ($unstaged as $entry) {
            $action = match ($entry->worktree) {
                \Pitmaster\Status\FileStatus::Modified => 'modified',
                \Pitmaster\Status\FileStatus::Deleted => 'deleted',
                default => $entry->worktree->value,
            };
            fwrite(STDOUT, "\t\033[31m{$action}:   {$entry->path}\033[0m\n");
        }
    }

    if ($untracked !== []) {
        fwrite(STDOUT, "\nUntracked files:\n");

        foreach ($untracked as $entry) {
            fwrite(STDOUT, "\t\033[31m{$entry->path}\033[0m\n");
        }
    }
}

function commandDiff(Repository $repo, array $args): void
{
    $cached = in_array('--cached', $args, true) || in_array('--staged', $args, true);
    $algorithm = 'myers';

    foreach ($args as $arg) {
        $algorithm = match ($arg) {
            '--patience' => 'patience',
            '--histogram' => 'histogram',
            '--minimal' => 'minimal',
            default => $algorithm,
        };
    }

    $results = $cached ? $repo->diffStaged(null, $algorithm) : $repo->diff(null, $algorithm);

    foreach ($results as $diff) {
        fwrite(STDOUT, ColorDiff::colorize($diff->format()));
    }
}

function commandAdd(Repository $repo, array $args): void
{
    if ($args === []) {
        fwrite(STDERR, "Usage: pitmaster add <file...>\n");
        exit(1);
    }

    $repo->add(...$args);
}

function commandCommit(Repository $repo, array $args): void
{
    $message = null;

    for ($i = 0; $i < count($args); $i++) {
        if ($args[$i] === '-m' && isset($args[$i + 1])) {
            $message = $args[$i + 1];
            break;
        }
    }

    $id = $repo->commit($message);
    $branch = $repo->branch() ?? 'detached HEAD';
    $summary = trim((string) strtok($repo->head()->message, "\n"));
    fwrite(STDOUT, "[{$branch} " . substr($id->hex, 0, 7) . "] {$summary}\n");
}

function commandBranch(Repository $repo, array $args): void
{
    if ($args === []) {
        $current = $repo->branch();

        foreach ($repo->branches() as $branch) {
            $prefix = $branch === $current ? '* ' : '  ';
            fwrite(STDOUT, "{$prefix}{$branch}\n");
        }

        return;
    }

    $name = $args[0];

    if ($name === '-d' || $name === '-D') {
        if (!isset($args[1])) {
            fwrite(STDERR, "Usage: pitmaster branch -d <name>\n");
            exit(1);
        }

        $repo->deleteBranch($args[1]);
        fwrite(STDOUT, "Deleted branch {$args[1]}\n");
        return;
    }

    $repo->createBranch($name);
    fwrite(STDOUT, "Created branch {$name}\n");
}

function commandTag(Repository $repo, array $args): void
{
    if ($args === []) {
        foreach ($repo->tags() as $tag) {
            fwrite(STDOUT, "{$tag}\n");
        }

        return;
    }

    $name = $args[0];
    $message = null;

    for ($i = 1; $i < count($args); $i++) {
        if ($args[$i] === '-m' && isset($args[$i + 1])) {
            $message = $args[$i + 1];
            break;
        }
    }

    if ($message !== null) {
        $repo->createTag($name, $message);
    } else {
        $headId = $repo->resolve('HEAD');
        $repo->updateRef("refs/tags/{$name}", $headId);
    }

    fwrite(STDOUT, "Created tag {$name}\n");
}

function commandCheckout(Repository $repo, array $args): void
{
    if (!isset($args[0])) {
        fwrite(STDERR, "Usage: pitmaster checkout <branch|commit>\n");
        exit(1);
    }

    $repo->checkout($args[0]);
    fwrite(STDOUT, "Switched to '{$args[0]}'\n");
}

function commandMerge(Repository $repo, array $args): void
{
    if ($args === []) {
        fwrite(STDERR, "Usage: pitmaster merge <branch...>|-s <ours|ort|recursive> <branch>|--continue|--abort\n");
        exit(1);
    }

    if ($args[0] === '--continue') {
        try {
            $repo->mergeContinue();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot continue: no merge in progress') {
                fwrite(STDERR, "fatal: There is no merge in progress (MERGE_HEAD missing).\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    if ($args[0] === '--abort') {
        $repo->mergeAbort();
        return;
    }

    if ($args[0] === '-s') {
        if (isset($args[1], $args[2]) && in_array($args[1], ['ours', 'ort', 'recursive'], true)) {
            $result = $repo->merge($args[2], $args[1]);

            fwrite(STDOUT, "Merge successful.\n");

            return;
        }

        fwrite(STDERR, "Unsupported merge strategy.\n");
        exit(1);
    }

    $result = count($args) > 1 ? $repo->mergeOctopus($args) : $repo->merge($args[0]);

    if ($result->clean) {
        fwrite(STDOUT, "Merge successful.\n");
    } else {
        fwrite(STDERR, "CONFLICT in: " . implode(', ', $result->conflictPaths) . "\n");
        exit(1);
    }
}

function commandBisect(Repository $repo, array $args): void
{
    if ($args === []) {
        fwrite(STDERR, "Usage: pitmaster bisect start <bad> <good>|good [rev]|bad [rev]|reset\n");
        exit(1);
    }

    match ($args[0]) {
        'start' => (function () use ($repo, $args): void {
            if (!isset($args[1], $args[2])) {
                fwrite(STDERR, "Usage: pitmaster bisect start <bad> <good>\n");
                exit(1);
            }

            $candidate = $repo->bisectStart($args[1], $args[2]);
            fwrite(STDOUT, $candidate->hex . "\n");
        })(),
        'good' => (function () use ($repo, $args): void {
            $candidate = $repo->bisectGood($args[1] ?? null);

            if ($candidate !== null) {
                fwrite(STDOUT, $candidate->hex . "\n");
            }
        })(),
        'bad' => (function () use ($repo, $args): void {
            $candidate = $repo->bisectBad($args[1] ?? null);

            if ($candidate !== null) {
                fwrite(STDOUT, $candidate->hex . "\n");
            }
        })(),
        'reset' => $repo->bisectReset(),
        default => (function (): void {
            fwrite(STDERR, "Usage: pitmaster bisect start <bad> <good>|good [rev]|bad [rev]|reset\n");
            exit(1);
        })(),
    };
}

function commandCherryPick(Repository $repo, array $args): void
{
    if ($args === []) {
        fwrite(STDERR, "Usage: pitmaster cherry-pick <rev>|--continue|--abort\n");
        exit(1);
    }

    if ($args[0] === '--continue') {
        try {
            $repo->cherryPickContinue();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot continue: no cherry-pick in progress') {
                fwrite(STDERR, "error: no cherry-pick or revert in progress\n");
                fwrite(STDERR, "fatal: cherry-pick failed\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    if ($args[0] === '--abort') {
        try {
            $repo->cherryPickAbort();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot abort: no cherry-pick in progress') {
                fwrite(STDERR, "error: no cherry-pick or revert in progress\n");
                fwrite(STDERR, "fatal: cherry-pick failed\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    $repo->cherryPick($args[0]);
}

function commandRevert(Repository $repo, array $args): void
{
    if ($args === []) {
        fwrite(STDERR, "Usage: pitmaster revert <rev>|--continue|--abort\n");
        exit(1);
    }

    if ($args[0] === '--continue') {
        try {
            $repo->revertContinue();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot continue: no revert in progress') {
                fwrite(STDERR, "error: no cherry-pick or revert in progress\n");
                fwrite(STDERR, "fatal: revert failed\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    if ($args[0] === '--abort') {
        try {
            $repo->revertAbort();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot abort: no revert in progress') {
                fwrite(STDERR, "error: no cherry-pick or revert in progress\n");
                fwrite(STDERR, "fatal: revert failed\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    $repo->revert($args[0]);
}

function commandRebase(Repository $repo, array $args): void
{
    if ($args === []) {
        fwrite(STDERR, "Usage: pitmaster rebase <ref>|--continue|--abort|--skip\n");
        exit(1);
    }

    if ($args[0] === '--continue') {
        try {
            $repo->rebaseContinue();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot continue: no rebase in progress') {
                fwrite(STDERR, "fatal: no rebase in progress\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    if ($args[0] === '--abort') {
        try {
            $repo->rebaseAbort();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot abort: no rebase in progress') {
                fwrite(STDERR, "fatal: no rebase in progress\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    if ($args[0] === '--skip') {
        try {
            $repo->rebaseSkip();
        } catch (\RuntimeException $e) {
            if ($e->getMessage() === 'Cannot skip: no rebase in progress') {
                fwrite(STDERR, "fatal: no rebase in progress\n");
                exit(128);
            }

            throw $e;
        }
        return;
    }

    $repo->rebase($args[0]);
}

function commandStash(Repository $repo, array $args): void
{
    $stash = new \Pitmaster\Stash\Stash(
        $repo->objectDatabase(),
        $repo->refDatabase(),
        $repo->gitDir(),
        $repo->workDir(),
    );

    $subcommand = $args[0] ?? 'push';

    match ($subcommand) {
        'push', 'save' => (function () use ($stash, $args) {
            $message = $args[1] ?? '';
            $id = $stash->push($message);
            fwrite(STDOUT, "Saved working directory to stash " . substr($id->hex, 0, 7) . "\n");
        })(),
        'pop' => (function () use ($stash) {
            $stash->pop();
            fwrite(STDOUT, "Applied and dropped stash\n");
        })(),
        'apply' => (function () use ($stash) {
            $stash->apply();
            fwrite(STDOUT, "Applied stash\n");
        })(),
        'list' => (function () use ($stash) {
            foreach ($stash->listEntries() as $entry) {
                fwrite(STDOUT, "stash@{{$entry['index']}}: {$entry['message']}\n");
            }
        })(),
        'drop' => (function () use ($stash) {
            $stash->drop();
            fwrite(STDOUT, "Dropped stash\n");
        })(),
        default => (function () use ($subcommand) {
            fwrite(STDERR, "Unknown stash command: {$subcommand}\n");
            exit(1);
        })(),
    };
}

function commandBlame(Repository $repo, array $args): void
{
    if (!isset($args[0])) {
        fwrite(STDERR, "Usage: pitmaster blame <file>\n");
        exit(1);
    }

    $headId = $repo->resolve('HEAD');
    $blame = new \Pitmaster\Graph\Blame($repo->objectDatabase());
    $result = $blame->blame($headId, $args[0]);

    foreach ($result as $line) {
        fwrite(STDOUT, sprintf(
            "%s (%s) %s\n",
            substr($line['hash'], 0, 8),
            substr($line['author'], 0, 30),
            $line['content'],
        ));
    }
}

function commandGrep(Repository $repo, array $args): void
{
    $ignoreCase = false;
    $regex = false;
    $pattern = null;

    foreach ($args as $arg) {
        if ($arg === '-i' || $arg === '--ignore-case') {
            $ignoreCase = true;
            continue;
        }

        if ($arg === '-E' || $arg === '--extended-regexp' || $arg === '--regex') {
            $regex = true;
            continue;
        }

        $pattern = $arg;
        break;
    }

    if ($pattern === null) {
        fwrite(STDERR, "Usage: pitmaster grep [-i] [-E] <pattern>\n");
        exit(1);
    }

    $headCommit = $repo->head();
    $grep = new \Pitmaster\Graph\Grep($repo->objectDatabase());
    $results = $grep->grep($headCommit->tree, $pattern, '', [
        'regex' => $regex,
        'ignore_case' => $ignoreCase,
    ]);

    foreach ($results as $match) {
        fwrite(STDOUT, "{$match['path']}:{$match['line']}:{$match['content']}\n");
    }
}

function commandReflog(Repository $repo, array $args): void
{
    $ref = 'HEAD';
    $limit = 10;
    $format = '%gd: %gs';

    if (($args[0] ?? null) === 'show') {
        if (isset($args[1]) && !str_starts_with($args[1], '-')) {
            $ref = $args[1];
            array_splice($args, 0, 2);
        } else {
            array_shift($args);
        }
    }

    for ($i = 0; $i < count($args); $i++) {
        $arg = $args[$i];

        if (str_starts_with($arg, '--format=')) {
            $format = substr($arg, 9);
            continue;
        }

        if (($arg === '-n' || $arg === '--max-count') && isset($args[$i + 1])) {
            $limit = max(0, (int) $args[$i + 1]);
            $i++;
            continue;
        }

        if (preg_match('/^-n(\d+)$/', $arg, $matches)) {
            $limit = max(0, (int) $matches[1]);
        }
    }

    $logBase = $ref === 'HEAD' ? $repo->gitDir() : $repo->commonGitDir();
    $reflog = Reflog::open($logBase, $ref);
    $entries = array_reverse($reflog->entries());

    if ($limit > 0) {
        $entries = array_slice($entries, 0, $limit);
    }

    foreach ($entries as $index => $entry) {
        fwrite(STDOUT, formatReflogEntry($format, $ref, $entry, $index) . "\n");
    }
}

/**
 * @param array{old: string, new: string, identity: string, message: string} $entry
 */
function formatReflogEntry(string $format, string $ref, array $entry, int $index): string
{
    $headRef = $ref === 'HEAD' ? 'HEAD' : $ref;
    $shortNew = substr($entry['new'], 0, 7);

    return strtr($format, [
        '%gD' => $headRef . '@{' . $index . '}',
        '%gd' => $headRef . '@{' . $index . '}',
        '%gs' => $entry['message'],
        '%H' => $entry['new'],
        '%h' => $shortNew,
    ]);
}

function commandRefs(Repository $repo): void
{
    foreach ($repo->allRefs() as $name => $hash) {
        fwrite(STDOUT, "{$hash} {$name}\n");
    }
}

function commandReset(Repository $repo, array $args): void
{
    $mode = 'mixed';
    $rev = null;

    foreach ($args as $arg) {
        if ($arg === '--soft') {
            $mode = 'soft';
        } elseif ($arg === '--hard') {
            $mode = 'hard';
        } elseif ($arg === '--mixed') {
            $mode = 'mixed';
        } else {
            $rev = $arg;
        }
    }

    if ($rev === null) {
        fwrite(STDERR, "Usage: pitmaster reset [--soft|--mixed|--hard] <commit>\n");
        exit(1);
    }

    $repo->reset($rev, $mode);
    fwrite(STDOUT, "HEAD is now at " . substr($repo->resolve($rev)->hex, 0, 7) . "\n");
}
