#!/usr/bin/env php
<?php 
declare (strict_types=1);
namespace Onumia\Lib;

/**
 * Import ALL libgit2 test fixtures (auto-discover).
 */
$root = \dirname(__DIR__);
$upstreamDir = $root . '/scenarios/upstream/libgit2';
$source = $root . '/fixtures/upstream/libgit2/tests/resources';
$setupHeader = <<<'BASH'
#!/bin/bash
set -e
PITMASTER_ROOT="${PITMASTER_ROOT:-$(cd "$(dirname "$0")/../../../.." && pwd)}"
BASH;
$setupHeader .= "\n";
if (!\is_dir($source)) {
    \fwrite(\STDERR, "Vendored libgit2 fixtures not found at {$source}\n");
    exit(1);
}
if (!\is_dir($upstreamDir)) {
    \mkdir($upstreamDir, 0777, \true);
}
$imported = 0;
foreach (\scandir($source) as $name) {
    if ($name === '.' || $name === '..') {
        continue;
    }
    $sourcePath = $source . '/' . $name;
    if (!\is_dir($sourcePath)) {
        continue;
    }
    // Determine type
    $type = null;
    if (\is_dir($sourcePath . '/.gitted')) {
        $type = 'gitted';
    } elseif (\is_file($sourcePath . '/HEAD')) {
        $type = 'bare';
    }
    if ($type === null) {
        continue;
    }
    $safeName = \str_replace('.git', '', \str_replace('.', '-', $name));
    $scenarioDir = $upstreamDir . '/' . $safeName;
    if (\is_dir($scenarioDir)) {
        continue;
    }
    \mkdir($scenarioDir, 0777, \true);
    if ($type === 'gitted') {
        $fixturePath = '${PITMASTER_ROOT}/fixtures/upstream/libgit2/tests/resources/' . $name . '/.gitted';
        $setup = $setupHeader . 'cp -r ' . \escapeshellarg($fixturePath) . " .git\n" . "git checkout -- . 2>/dev/null || true\n";
    } else {
        $fixturePath = '${PITMASTER_ROOT}/fixtures/upstream/libgit2/tests/resources/' . $name;
        $setup = $setupHeader . "git init .\n" . 'cp -r ' . \escapeshellarg($fixturePath) . "/* .git/\n" . "git checkout -- . 2>/dev/null || true\n";
    }
    \file_put_contents($scenarioDir . '/setup.sh', $setup);
    \chmod($scenarioDir . '/setup.sh', 0755);
    \file_put_contents($scenarioDir . '/scenario.json', \json_encode(['name' => 'upstream/libgit2/' . $safeName, 'category' => 'upstream', 'description' => 'libgit2: ' . $name, 'operations' => [], 'oracle_commands' => [], 'expectations' => ['exact_match' => [], 'fsck_clean' => \false]], \JSON_PRETTY_PRINT | \JSON_UNESCAPED_SLASHES) . "\n");
    $imported++;
    \fwrite(\STDOUT, "  OK    {$name}\n");
}
\fwrite(\STDOUT, "\nImported {$imported} libgit2 fixtures (total: " . \count(\glob($upstreamDir . '/*/scenario.json')) . ")\n");
