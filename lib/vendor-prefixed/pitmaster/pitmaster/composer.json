{
    "name": "pitmaster\/pitmaster",
    "description": "Pure PHP Git implementation. Reads and writes Git repositories without shelling out to git.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "inline0",
            "homepage": "https:\/\/github.com\/inline0"
        }
    ],
    "homepage": "https:\/\/github.com\/inline0\/pitmaster",
    "support": {
        "issues": "https:\/\/github.com\/inline0\/pitmaster\/issues",
        "source": "https:\/\/github.com\/inline0\/pitmaster"
    },
    "keywords": [
        "git",
        "php",
        "vcs",
        "repository",
        "diff",
        "merge",
        "pack"
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-zlib": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit\/phpunit": "^13.1",
        "phpstan\/phpstan": "^2.0",
        "squizlabs\/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Onumia\\Lib\\Pitmaster\\": "src\/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Onumia\\Lib\\Pitmaster\\Tests\\": "tests\/",
            "Onumia\\Lib\\Pitmaster\\Bench\\": "bench\/lib\/"
        }
    },
    "config": {
        "process-timeout": 0,
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": [
            "@test:phpunit",
            "@test:oracle"
        ],
        "test:phpunit": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:oracle": ".\/bin\/test-regression",
        "test:mutation": "php .\/bin\/mutation-smoke",
        "bench": ".\/bin\/bench",
        "bench:baseline": ".\/bin\/bench-baseline",
        "bench:compare": ".\/bin\/bench-compare",
        "bench:summary": ".\/bin\/bench-summary",
        "bench:verify": ".\/bin\/bench-verify",
        "verify:evidence": "php .\/bin\/verify-support-evidence",
        "verify:drift": "php .\/bin\/audit-upstream-drift",
        "verify:proof": "php .\/bin\/build-proof-artifact .pitmaster\/proof\/proof-artifact.json",
        "audit:composer": "composer audit --locked --no-interaction",
        "verify": [
            "@verify:evidence",
            "@verify:drift",
            "@verify:proof",
            "@test:mutation",
            "@audit:composer",
            "@analyse",
            "@cs",
            "@test"
        ],
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
        "cs": "phpcs --warning-severity=0",
        "cs:fix": "phpcbf"
    },
    "bin": [
        "bin\/pitmaster"
    ]
}